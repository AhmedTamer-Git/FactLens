{
  "ConnectionStrings": {
    // Example: "Server=YOUR_SERVER;Database=YOUR_DB;Trusted_Connection=True;TrustServerCertificate=True;"
    "DefaultConnection": "YOUR_DATABASE_CONNECTION_STRING_HERE"
  },

  "Jwt": {
    // Secret key for token encryption (Minimum 32 characters recommended)
    "Key": "YOUR_SUPER_SECRET_LONG_KEY_AT_LEAST_32_CHARS",
    "Issuer": "YOUR_API_ISSUER_NAME",
    "Audience": "YOUR_CLIENT_AUDIENCE_NAME"
  },

  "AdminSeed": {
    // Initial admin credentials for first-time database seeding
    "Email": "admin@example.com",
    "Password": "YOUR_SECURE_ADMIN_PASSWORD"
  },

  "EmailSettings": {
    // SMTP configuration (e.g., smtp.gmail.com)
    "Host": "YOUR_SMTP_HOST",
    "Port": 587,
    "Email": "YOUR_EMAIL_ADDRESS",
    "Password": "YOUR_APP_SPECIFIC_PASSWORD"
  },

  "Ai": {
    // Base URL for external AI services (e.g., OpenAI or Custom API)
    "BaseUrl": "https://api.example-ai.com/"
  },

  "Authentication": {
    "Google": {
      // Credentials from Google Cloud Console
      "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },

  "AISettings": {
    // Rate limiting for AI feature usage
    "MaxRequestsPerUserPerDay": 0
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}